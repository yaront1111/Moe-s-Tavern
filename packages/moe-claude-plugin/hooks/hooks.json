{
  "description": "Moe plugin hooks — forward mcp__moe__ tool events to the local daemon.",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.mjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
